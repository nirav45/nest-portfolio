# .env file

# Application Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb://localhost:27017/nest-portfolio

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=1d

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_BUCKET=portfolio-images

# Storage Configuration
STORAGE_PROVIDER=s3

# s3
AWS_ACCESS_KEY_ID=AKIA....
AWS_SECRET_ACCESS_KEY=abc123....
AWS_REGION=ap-south-1
AWS_S3_BUCKET=my-demo-images
AWS_S3_BASE_FOLDER=nirav
AWS_S3_PUBLIC_BASE_URL=https://my-demo-images.s3.ap-south-1.amazonaws.com
